{
  "name": "@omniagent-plus/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc -p tsconfig.json --pretty false",
    "typecheck": "tsc -p tsconfig.json --pretty false",
    "test": "sh -c 'if [ \"$1\" = \"--\" ]; then shift; fi; pnpm --dir ../.. exec vitest --config vitest.config.ts \"$@\"' --",
    "cli": "tsx src/bin.ts"
  },
  "dependencies": {
    "@omniagent-plus/coordinator": "workspace:*",
    "@consiliency/runtime-provider": "workspace:*",
    "@omniagent-plus/identity-isolation": "workspace:*",
    "@omniagent-plus/rate-limit-catalog": "workspace:*",
    "@omniagent-plus/state-ledger": "workspace:*",
    "@omniagent-plus/worktree-leasing": "workspace:*",
    "tsx": "^4.8.1",
    "zod": "^3.25.76"
  }
}
